                    <h4><%= manga.title %></h4>

                    <p>
                        CHƯƠNG <%= manga.lastChapter || 0 %> -
                        <%= timeAgo(manga.lastChapterDate) %>
                    </p>

                    <small>
                        <%= (manga.weeklyViews || 0).toLocaleString("vi-VN") %>
                        LƯỢT XEM
                    </small>

                </div>

                <span class="rank-number">
                    <%= String(i + 1).padStart(2,"0") %>
                </span>

            </a>

            <% }) %>

        </div>

        <!-- THÁNG -->

        <div
            class="rank-row"
            id="monthRank"
            style="display:none"
        >

            <% topMonth.slice(0,24).forEach((manga, i) => { %>

