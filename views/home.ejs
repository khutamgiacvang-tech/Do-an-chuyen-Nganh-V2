<%
// Helper hiển thị thời gian tương đối kiểu "12 phút trước"
function timeAgo(date){

    if(!date) return "";

    const diff = Date.now() - new Date(date).getTime();

    const mins = Math.floor(diff / 60000);

    if(mins < 1) return "vừa xong";
    if(mins < 60) return mins + " phút trước";

    const hours = Math.floor(mins / 60);
    if(hours < 24) return hours + " giờ trước";

    const days = Math.floor(hours / 24);
    if(days < 30) return days + " ngày trước";

    const months = Math.floor(days / 30);
    if(months < 12) return months + " tháng trước";

    return Math.floor(months / 12) + " năm trước";
}
%>

<!-- =========================
        HERO CAROUSEL
========================= -->

<section class="hero">

    <div class="hero-track" id="heroTrack">

        <% mangas.slice(0,5).forEach(manga => { %>

        <a href="/manga/<%= manga.slug %>" class="hero-slide">

            <img
                src="<%= manga.banner || manga.cover %>"
                alt="<%= manga.title %>"
                class="hero-banner"
            >

            <div class="hero-overlay"></div>

            <div class="hero-content">

                <div class="hero-info">

                    <h1><%= manga.title %></h1>

                    <p class="hero-desc">
                        <%= manga.description || "Chưa có mô tả." %>
                    </p>

                </div>

            </div>

            <span class="hero-cta">XEM THÔNG TIN</span>

        </a>

        <% }) %>

    </div>

    <div class="hero-dots" id="heroDots">

        <% mangas.slice(0,5).forEach((manga, i) => { %>

            <button
                type="button"
                class="hero-dot <%= i===0 ? 'active' : '' %>"
                data-index="<%= i %>"
            ></button>

        <% }) %>

    </div>

</section>

<!-- =========================
        TRUYỆN MỚI (cuộn ngang)
========================= -->

<section class="section">

    <div class="section-title">
        <h2>TRUYỆN MỚI</h2>
    </div>

    <div class="row-wrapper">

        <!-- Nút lùi -->

        <button
            type="button"
            class="row-arrow row-arrow-left"
            onclick="document.getElementById('rowNew').scrollBy({left:-600,behavior:'smooth'})"
        >
            ‹
        </button>

        <div class="home-row home-row-new" id="rowNew">

            <% mangas.slice(0,24).forEach(manga => { %>

            <a href="/manga/<%= manga.slug %>" class="home-card">

                <img
                    src="<%= manga.cover || '/images/no-cover.png' %>"
                    alt="<%= manga.title %>"
                >

                <div class="home-card-body">

                    <h3><%= manga.title %></h3>

                    <p>
                        C. <%= manga.lastChapter || 0 %> -
                        <%= timeAgo(manga.lastChapterDate) %>
                    </p>

                </div>

            </a>

            <% }) %>

        </div>

        <!-- Nút tiến -->

        <button
            type="button"
            class="row-arrow row-arrow-right"
            onclick="document.getElementById('rowNew').scrollBy({left:600,behavior:'smooth'})"
        >
            ›
        </button>

    </div>

    <div class="section-footer">
        <a href="/manga?sort=new">› Xem danh sách truyện mới</a>
    </div>

</section>

<!-- =========================
        TRUYỆN NỔI BẬT (xếp hạng)
========================= -->

<section class="section">

    <div class="section-title">

        <h2>TRUYỆN NỔI BẬT</h2>

        <div class="rank-tabs">

            <button type="button" class="rank-tab active" data-range="week">TUẦN</button>
            <button type="button" class="rank-tab" data-range="month">THÁNG</button>
            <button type="button" class="rank-tab" data-range="all">MỌI LÚC</button>

        </div>

    </div>

    <div class="row-wrapper">

        <!-- Nút trái -->

        <button
            type="button"
            class="row-arrow row-arrow-left"
            onclick="scrollRank(-600)"
        >
            ‹
        </button>

        <!-- TUẦN -->

        <div class="rank-row" id="weekRank">

            <% topWeek.forEach((manga, i) => { %>

            <a href="/manga/<%= manga.slug %>" class="rank-card">

                <img
                    src="<%= manga.cover || '/images/no-cover.png' %>"
                    alt="<%= manga.title %>"
                >

