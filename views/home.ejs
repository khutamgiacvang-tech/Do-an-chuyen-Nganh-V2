                        <%= (manga.monthlyViews || 0).toLocaleString("vi-VN") %>
                        LƯỢT XEM
                    </small>

                </div>

                <span class="rank-number">
                    <%= String(i + 1).padStart(2,"0") %>
                </span>

            </a>

            <% }) %>

        </div>

        <!-- MỌI LÚC -->

        <div
            class="rank-row"
            id="allRank"
            style="display:none"
        >

            <% topAll.slice(0,24).forEach((manga, i) => { %>

            <a href="/manga/<%= manga.slug %>" class="rank-card">

