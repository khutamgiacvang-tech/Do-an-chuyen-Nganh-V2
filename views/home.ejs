<script>

/* ===== HERO CAROUSEL ===== */

const heroTrack = document.getElementById("heroTrack");
const heroDots = document.querySelectorAll(".hero-dot");

heroDots.forEach(dot => {

    dot.addEventListener("click", () => {

        const index = Number(dot.dataset.index);
        const slide = heroTrack.children[index];

        heroTrack.scrollTo({
            left: slide.offsetLeft,
            behavior: "smooth"
        });

    });

});

function updateActiveDot(){

    const scrollLeft = heroTrack.scrollLeft;

    let closest = 0;
    let closestDist = Infinity;

    [...heroTrack.children].forEach((slide, i) => {

        const dist = Math.abs(slide.offsetLeft - scrollLeft);

        if(dist < closestDist){
            closestDist = dist;
            closest = i;
        }

    });

    heroDots.forEach((dot, i) => {
        dot.classList.toggle("active", i === closest);
    });

}

heroTrack.addEventListener("scroll", () => {

    window.requestAnimationFrame(updateActiveDot);

});

/* Tự động chuyển slide */

let heroAutoIndex = 0;

setInterval(() => {

    if(!heroTrack.children.length) return;

    heroAutoIndex = (heroAutoIndex + 1) % heroTrack.children.length;

    heroTrack.scrollTo({
        left: heroTrack.children[heroAutoIndex].offsetLeft,
        behavior: "smooth"
    });

}, 6000);

/* ===== RANK TABS ===== */

document.querySelectorAll(".rank-tab").forEach(tab => {

    tab.addEventListener("click", () => {

        document.querySelectorAll(".rank-tab")
            .forEach(t => t.classList.remove("active"));

        tab.classList.add("active");

        document.getElementById("weekRank").style.display = "none";
        document.getElementById("monthRank").style.display = "none";
        document.getElementById("allRank").style.display = "none";

        if(tab.dataset.range === "week"){
            document.getElementById("weekRank").style.display = "";
        }

        if(tab.dataset.range === "month"){
            document.getElementById("monthRank").style.display = "";
        }

        if(tab.dataset.range === "all"){
            document.getElementById("allRank").style.display = "";
        }

    });

});

function scrollRank(amount){

    let activeRow = document.getElementById("weekRank");

    if(document.getElementById("monthRank").style.display !== "none"){
        activeRow = document.getElementById("monthRank");
    }

    if(document.getElementById("allRank").style.display !== "none"){
        activeRow = document.getElementById("allRank");
    }

    activeRow.scrollBy({
        left: amount,
        behavior: "smooth"
    });

}

</script>