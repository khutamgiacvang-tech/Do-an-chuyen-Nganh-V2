<div class="upload-page">

    <div class="upload-card">

        <h1>

            🖼 Đổi Cover

        </h1>

        <p class="sub-title">

            <%= manga.title %>

        </p>

        <div style="text-align:center;margin-bottom:35px;">

            <img

                src="<%= manga.cover %>"

                style="width:220px;border-radius:15px;">

        </div>

        <form

            action="/my-manga/<%= manga.slug %>/cover"

            method="POST"

            enctype="multipart/form-data">

            <div class="form-group">

                <label>

                    Cover mới

                </label>

                <input

                    type="file"

                    name="cover"

                    accept="image/*"

                    required>

            </div>

            <div class="manage-buttons">

                <button

                    class="upload-btn">

                    💾 Lưu

                </button>

                <a

                    href="/my-manga/<%= manga.slug %>"

                    class="edit-btn">

                    ← Quay lại

                </a>

            </div>

        </form>

    </div>

</div>