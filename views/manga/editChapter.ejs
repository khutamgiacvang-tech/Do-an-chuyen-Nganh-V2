<div class="translator-page">
  <h1>✏️ Sửa Chapter</h1>

  <p class="subtitle"><%= manga.title %></p>

  <form
    action="/my-manga/<%= manga.slug %>/chapter/<%= chapter._id %>/edit"
    method="POST"
    enctype="multipart/form-data"
  >
    <div class="form-group">
      <label> Chapter </label>

      <input
        type="number"
        name="chapterNumber"
        value="<%= chapter.chapterNumber %>"
        step="0.1"
        required
      />
    </div>

    <div class="form-group">
      <label> Tiêu đề </label>

      <input type="text" name="title" value="<%= chapter.title %>" />
    </div>

    <div class="form-group">
      <label> ZIP mới (Không bắt buộc) </label>

      <input type="file" name="zip" accept=".zip," />
    </div>

    <div class="edit-actions">
      <button type="submit" class="submit-btn">💾 Lưu thay đổi</button>

      <a href="/my-manga/<%= manga.slug %>" class="cancel-btn"> Hủy </a>
    </div>
  </form>
</div>
