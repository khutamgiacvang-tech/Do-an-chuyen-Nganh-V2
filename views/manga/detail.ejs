<%
function timeAgo(date){

    if(!date) return "";

    const diff = Date.now() - new Date(date).getTime();

    const seconds = Math.floor(diff / 1000);

    if(seconds < 60)
        return "vừa xong";

    const mins = Math.floor(seconds / 60);

    if(mins < 60)
        return mins + " phút trước";

    const hours = Math.floor(mins / 60);

    if(hours < 24)
        return hours + " giờ trước";

    const days = Math.floor(hours / 24);

    if(days < 30)
        return days + " ngày trước";

    const months = Math.floor(days / 30);

    if(months < 12)
        return months + " tháng trước";

    return Math.floor(months / 12) + " năm trước";
}
%>

<div class="manga-page">

    <div class="manga-card">

        <!-- Banner -->
        <div class="manga-banner">

            <img
                src="<%= manga.banner || manga.cover %>"
                alt="<%= manga.title %>"
                class="manga-banner-img"
            >

        </div>

        <!-- Header -->
        <div class="manga-header">

            <div class="cover-wrapper">

                <img
                    src="<%= manga.cover %>"
                    class="manga-cover"
                    alt="<%= manga.title %>"
                >

            </div>

            <div class="manga-info">

                <h1><%= manga.title %></h1>

                <div class="author-line">

                    <span>
                        <strong>Tác giả:</strong>
                        <%= manga.author || "Đang cập nhật" %>
                    </span>

                    <span>
                        <strong>Họa sĩ:</strong>
                        <%= manga.artist || "Đang cập nhật" %>
                    </span>

                </div>

                <div class="genre-list">

                    <% if(manga.genres && manga.genres.length){ %>

                        <% manga.genres.forEach(g=>{ %>

                            <span class="genre-tag">
                                <%= g %>
                            </span>

                        <% }) %>

                    <% } %>

                </div>

                <div class="status-line">

                    <% if(manga.publishStatus==="ongoing"){ %>

                        <span class="status ongoing">
                            ĐANG TIẾN HÀNH
                        </span>

                    <% } else if(manga.publishStatus==="completed"){ %>

                        <span class="status completed">
                            HOÀN THÀNH
                        </span>

                    <% } else { %>

                        <span class="status hiatus">
                            TẠM NGƯNG
                        </span>

                    <% } %>

                </div>

                <div class="action-buttons">

                    <% if(chapters.length){ %>

                        <a
                            href="/manga/<%= manga.slug %>/chapter/<%= chapters[chapters.length-1].chapterNumber %>"
                            class="btn-follow"
                        >
                            📚 Đọc từ đầu
                        </a>

                        <a
                            href="/manga/<%= manga.slug %>/chapter/<%= chapters[0].chapterNumber %>"
                            class="btn-read"
                        >
                            ⚡ Chương mới nhất
                        </a>

                    <% } %>

                    <% if(!isOwner){ %>

                        <form
                            action="/manga/<%= manga.slug %>/follow"
                            method="POST"
                            class="follow-form"
                        >

                            <button
                                type="submit"
                                class="btn-follow-toggle <%= isFollowing ? 'active' : '' %>"
                            >

                                <% if(isFollowing){ %>

                                    ✅ Đã theo dõi

                                <% } else { %>

                                    🤍 Theo dõi

                                <% } %>

                            </button>

                        </form>

                    <% } %>

                </div>

            </div>

        </div>

        <!-- BODY -->
        <div class="detail-layout">

            <!-- LEFT -->
             <div class="main-content">

                <div class="info-box">

                    <div class="detail-translator-card">

                        <div class="translator-top">

                            <a
                                href="/translator/<%= manga.translator?.username %>"
                                class="translator-identity"
                            >

                                <img
                                    src="<%= manga.translator?.avatar || '/images/default-avatar.png' %>"
                                    class="translator-avatar"
                                    alt="translator"
                                >

                                <div class="translator-meta">

                                    <div class="translator-name">

                                        <%= manga.translator?.displayName || manga.translator?.username || "Translator" %>

                                    </div>

                                    <div class="translator-count">

                                        <%= manga.translator?.mangaCount || 1 %> TRUYỆN

                                    </div>

                                </div>

                            </a>

                            <% if(manga.translator?.facebook){ %>

                                <div class="translator-social">

                                    <a
                                        href="<%= manga.translator.facebook %>"
                                        target="_blank"
                                        class="fb-chip"
                                    >
                                        <span class="fb-icon">f</span>
                                        <%= manga.translator.facebookHandle || "Facebook" %>
                                    </a>

                                    <% if(manga.translator?.messenger){ %>

                                        <a
                                            href="<%= manga.translator.messenger %>"
                                            target="_blank"
                                            class="msg-icon"
                                        >
                                            💬
                                        </a>

                                    <% } %>

                                </div>

                            <% } %>

                        </div>

                        <a
                            href="/translator/<%= manga.translator?.username %>"
                            class="btn-view-group"
                        >
                            👥 Xem trang nhóm
                        </a>

                    </div>

                    <hr>

                    <div class="description-content">

                        <%= manga.description || "Chưa có mô tả." %>

                    </div>

                </div>

                <!-- CHAPTER -->
                <div class="chapter-box">

                    <h3>DANH SÁCH CHƯƠNG</h3>

                    <% chapters.forEach(chapter=>{ %>

                        <a
                            href="/manga/<%= manga.slug %>/chapter/<%= chapter.chapterNumber %>"
                            class="chapter-item"
                        >

                            <div>

                                <strong>

                                    Chương <%= chapter.chapterNumber %>

                                </strong>

                                <div class="chapter-sub">

                                    <%= chapter.title || "Không có tiêu đề" %>

                                </div>

                            </div>

                            <div class="chapter-date">

                                <%= timeAgo(chapter.createdAt) %>

                            </div>

                        </a>

                    <% }) %>

                </div>

            </div>

            <!-- RIGHT -->
            <div class="sidebar">

                <div class="side-box">

                    <h4>THỐNG KÊ</h4>

                    <div class="stat-row">
                        📚 Số chương:
                        <strong><%= chapters.length %></strong>
                    </div>

                    <div class="stat-row">
                        👁️ Lượt xem:
                        <strong><%= manga.views || 0 %></strong>
                    </div>

                    <div class="stat-row">
                        ❤️ Theo dõi:
                        <strong><%= manga.follows || 0 %></strong>
                    </div>

                    <div class="stat-row">
                        💬 Bình luận:
                        <strong><%= manga.comments || 0 %></strong>
                    </div>

                    <div class="stat-row">
                        ⭐ Đánh giá:
                        <strong><%= manga.rating || 0 %></strong>
                    </div>

                </div>

                <div class="side-box">

                    <h4>CHIA SẺ</h4>

                    <div class="share-link-row">

                        <input
                            type="text"
                            class="share-link-input"
                            id="shareLink"
                            value="https://manganest.net/manga/<%= manga.slug %>"
                            readonly
                        >

                        <button
                            type="button"
                            class="copy-btn"
                            onclick="navigator.clipboard.writeText(document.getElementById('shareLink').value)"
                        >
                            📋
                        </button>

                    </div>

                    <div class="share-buttons">

                        <button
                            type="button"
                            class="btn-share"
                            onclick="if(navigator.share){navigator.share({title:'<%= manga.title %>', url:document.getElementById('shareLink').value})}"
                        >
                            ⤴ Chia sẻ
                        </button>

                        <a
                            href="https://www.facebook.com/sharer/sharer.php?u=https://manganest.net/manga/<%= manga.slug %>"
                            target="_blank"
                            class="btn-facebook"
                        >
                            📘 Facebook
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>
