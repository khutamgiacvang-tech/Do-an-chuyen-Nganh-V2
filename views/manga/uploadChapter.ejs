<div class="upload-page">

    <div class="upload-card">

        <h1>

            📖 Upload Chapter

        </h1>

        <p class="manga-name">

            <%= manga.title %>

        </p>

        <form

            action="/upload/<%= manga.slug %>/chapter"

            method="POST"

            enctype="multipart/form-data"

        >

            <div class="form-group">

                <label>

                    Chapter

                </label>

                <input

                    type="text"

                    name="chapterNumber"

                    step="0.1"

                    required

                >

            </div>

            <div class="form-group">

                <label>

                    Tiêu đề Chapter

                </label>

                <input

                    type="text"

                    name="title"

                    placeholder="Ví dụ: Khởi đầu"

                >

            </div>

            <div class="form-group">

                <label>

                    File ZIP

                </label>

                <input

                    type="file"

                    name="zip"

                    accept=".zip"

                    required

                >

            </div>

            <button
                class="upload-btn">

                🚀 Upload Chapter

            </button>

        </form>

    </div>

</div>