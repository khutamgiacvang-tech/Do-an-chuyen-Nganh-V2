<header class="navbar">

    <div class="container">

        <!-- Logo -->
        <a href="/" class="logo">
            📚 <span>MangaNest</span>
        </a>

        <!-- Menu -->
        <nav class="nav-menu">

            <a href="/">❤️ Ủng hộ</a>

            <a href="/translator/apply">📝 Đăng truyện</a>

            <a href="https://discord.gg/dREjzkdGu" target="_blank">
                💬 Discord
            </a>

            <a href="/community">👥 Cộng đồng</a>

        </nav>

        <div class="search-box">

            <i class="fa-solid fa-magnifying-glass"></i>

            <input
                type="text"
                id="searchInput"
                placeholder="Tìm kiếm truyện..."
                autocomplete="off"
            >

            <button type="button" id="searchClear" class="search-clear" style="display:none;">
                <i class="fa-solid fa-xmark"></i>
            </button>

            <div
                id="searchDropdown"
                class="search-dropdown"
            ></div>

        </div>

        <!-- User -->
        <div class="user-menu">

            <% if(user){ %>

            <!-- Notification -->

            <div class="notification-dropdown">

                <button class="notification-btn">

                    <i class="fa-regular fa-bell"></i>

                    <% if(unreadCount>0){ %>

                    <span
                        class="notification-badge"
                        id="notificationBadge">

                        <%= unreadCount %>

                    </span>

                    <% } %>

                </button>

                <div class="notification-menu">

                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">

                        <h4 style="margin:0;">
                            🔔 Thông báo
                        </h4>

                        <% if(notifications.length>0){ %>

                        <button
                            onclick="markAllRead()"
                            style="border:none;background:#5865F2;color:#fff;padding:6px 12px;border-radius:6px;cursor:pointer;">

                            Đọc tất cả

                        </button>

                        <% } %>

                    </div>

                    <div id="notificationList">

                        <% if(notifications.length>0){ %>

                        <% notifications.forEach(notification=>{ %>

                        <a
                            href="<%= notification.link %>"
                            data-id="<%= notification._id %>"
                            class="notification-item <%= notification.isRead ? '' : 'unread' %>"
                            onclick="readNotification(event,this)">

                            <strong>

                                <%= notification.title %>

                            </strong>

                            <br>

                            <%= notification.message %>

                            <small>

                                <%= notification.createdAt.toLocaleString("vi-VN") %>

                            </small>

                        </a>

                        <% }) %>

                        <% }else{ %>

                        <div class="empty-notification">

                            Chưa có thông báo.

                        </div>

                        <% } %>

                    </div>

                </div>

            </div>

            <!-- Avatar -->

            <div class="user-dropdown">

                <img
                    class="avatar"
                    src="<%= user.avatar ? user.avatar : '/images/default-avatar.png' %>">

                <span>

                    <%= user.username %>

                </span>

                <div class="dropdown-menu">

                    <a href="/profile">

                        👤 Hồ sơ

                    </a>

                    <% if(user && user.role === "translator"){ %>

                    <a href="/my-manga" class="dropdown-item">
                        📚 Truyện của tôi
                    </a>

                    <% } %>

                    <a href="/translator/application">

                        📄 Đơn Translator

                    </a>

                    <a href="/library">

                        ❤️ Danh sách theo dõi

                    </a>

                    <a href="/history">

                        🕒 Lịch sử đọc

                    </a>

                    <% if(user.role==="admin"){ %>

                    <a href="/admin">

                        🛡 Quản trị

                    </a>

                    <% } %>

                    <a href="/logout">

                        🚪 Đăng xuất

                    </a>

                </div>

            </div>

            <% }else{ %>

            <button
                class="login-btn"
                onclick="openAuth()">

                <i class="fa-regular fa-user"></i>

                Đăng nhập

            </button>

            <% } %>

        </div>

    </div>

    <script>
    (function(){
        const input = document.getElementById('searchInput');
        const dropdown = document.getElementById('searchDropdown');
        const clearBtn = document.getElementById('searchClear');

        let debounceTimer;

        input.addEventListener('input', function(){
            const keyword = input.value.trim();

            clearBtn.style.display = input.value ? 'flex' : 'none';

            clearTimeout(debounceTimer);

            if(!keyword){
                dropdown.classList.remove('active');
                dropdown.innerHTML = '';
                return;
            }

            // Hiện skeleton loading ngay lập tức
            renderSkeleton();
            dropdown.classList.add('active');

            debounceTimer = setTimeout(() => {
                fetch('/api/search?q=' + encodeURIComponent(keyword))
                    .then(res => res.json())
                    .then(data => renderResults(data))
                    .catch(err => console.error('Search error:', err));
            }, 300); // debounce 300ms
        });

        clearBtn.addEventListener('click', function(){
            input.value = '';
            clearBtn.style.display = 'none';
            dropdown.classList.remove('active');
            dropdown.innerHTML = '';
            input.focus();
        });

        function renderSkeleton(){
            let html = '';

            for(let i = 0; i < 3; i++){
                html += `
                    <div class="search-skeleton-item">
                        <div class="skeleton-line title"></div>
                        <div class="skeleton-line thumb"></div>
                    </div>
                `;
            }

            dropdown.innerHTML = html;
        }

        function renderResults(mangas){
            dropdown.innerHTML = '';

            if(!mangas.length){
                dropdown.innerHTML = '<div class="search-empty">Không tìm thấy kết quả</div>';
            } else {
                mangas.forEach(manga => {
                    const item = document.createElement('a');
                    item.href = '/manga/' + manga.slug;
                    item.className = 'search-item';
                    item.innerHTML = `
                        <img src="${manga.cover}" alt="${manga.title}">
                        <span>${manga.title}</span>
                    `;
                    dropdown.appendChild(item);
                });
            }

            dropdown.classList.add('active');
        }

        // Ẩn dropdown khi click ra ngoài
        document.addEventListener('click', function(e){
            if(!e.target.closest('.search-box')){
                dropdown.classList.remove('active');
            }
        });
    })();
    </script>

</header>