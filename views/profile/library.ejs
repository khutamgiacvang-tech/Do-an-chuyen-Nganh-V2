<div class="library-page">

    <h1>
        ❤️ Danh sách theo dõi
    </h1>

    <% if(mangas.length === 0){ %>

        <div class="empty-box">

            Bạn chưa theo dõi truyện nào.

        </div>

    <% } else { %>

        <div class="library-grid">

            <% mangas.forEach(manga => { %>

                <a
                    href="/manga/<%= manga.slug %>"
                    class="library-card"
                >

                    <img
                        src="<%= manga.cover %>"
                        alt="<%= manga.title %>"
                    >

                    <div class="library-info">

                        <h3>
                            <%= manga.title %>
                        </h3>

                        <p>

                            Nhóm dịch:

                            <%= manga.translator?.displayName || manga.translator?.username %>

                        </p>

                        <small>

                            Cập nhật:
                            <%= new Date(manga.lastUpdated).toLocaleDateString("vi-VN") %>

                        </small>

                    </div>

                </a>

            <% }) %>

        </div>

    <% } %>

</div>