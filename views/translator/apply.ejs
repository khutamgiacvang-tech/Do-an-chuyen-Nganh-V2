<div class="translator-page">

    <div class="translator-card">

        <h1>📝 Đăng ký trở thành Translator</h1>

        <p class="subtitle">

            Hoàn thành biểu mẫu dưới đây để xin quyền đăng truyện trên MangaNest.

        </p>

        <form
            action="/translator/apply"
            method="POST"
            enctype="multipart/form-data"
        >

            <div class="form-group">

                <label>Tên nhóm dịch (nếu có)</label>

                <input
                    type="text"
                    name="groupName"
                    placeholder="Ví dụ: Akasha Team"
                >

            </div>

            <div class="form-group">

                <label>Giới thiệu bản thân</label>

                <textarea
                    name="introduction"
                    rows="5"
                    required
                    placeholder="Giới thiệu kinh nghiệm dịch truyện..."
                ></textarea>

            </div>

            <hr>

            <h3>📚 Dự án đã từng dịch</h3>

            <div id="projects">

                <div class="project-item">

                    <input
                        type="text"
                        name="projectTitle[]"
                        placeholder="Tên truyện"
                    >

                    <input
                        type="text"
                        name="projectWebsite[]"
                        placeholder="Website"
                    >

                    <input
                        type="url"
                        name="projectLink[]"
                        placeholder="Link truyện"
                    >

                </div>

            </div>

            <button
                type="button"
                class="add-btn"
                onclick="addProject()"
            >

                + Thêm dự án

            </button>

            <hr>

            <h3>🌐 Link Profile đã từng dịch</h3>

            <div id="profiles">

                <div class="profile-item">

                    <input
                        type="text"
                        name="profileWebsite[]"
                        placeholder="Website"
                    >

                    <input
                        type="url"
                        name="profileLink[]"
                        placeholder="Link Profile"
                    >

                </div>

            </div>

            <button
                type="button"
                class="add-btn"
                onclick="addProfile()"
            >

                + Thêm Profile

            </button>

            <hr>

            <div class="form-group">

                <label>Chap mẫu (tối đa 5 ảnh)</label>

                <input
                    type="file"
                    name="sampleImages"
                    multiple
                    accept="image/*"
                >

            </div>

            <div class="form-group">

                <label>Ghi chú</label>

                <textarea
                    name="note"
                    rows="4"
                    placeholder="Thông tin bổ sung..."
                ></textarea>

            </div>

            <div class="checkbox">

                <input
                    type="checkbox"
                    required
                >

                Tôi cam kết chỉ đăng các bản dịch thuộc quyền sở hữu của mình hoặc được phép đăng.

            </div>

            <button
                class="submit-btn"
                type="submit"
            >

                Gửi đơn xin cấp quyền

            </button>

        </form>

    </div>

</div>

<script>

function addProject(){

    document.getElementById("projects").insertAdjacentHTML(

        "beforeend",

        `

        <div class="project-item">

            <input type="text" name="projectTitle[]" placeholder="Tên truyện">

            <input type="text" name="projectWebsite[]" placeholder="Website">

            <input type="url" name="projectLink[]" placeholder="Link truyện">

        </div>

        `

    );

}

function addProfile(){

    document.getElementById("profiles").insertAdjacentHTML(

        "beforeend",

        `

        <div class="profile-item">

            <input type="text" name="profileWebsite[]" placeholder="Website">

            <input type="url" name="profileLink[]" placeholder="Link Profile">

        </div>

        `

    );

}

</script>